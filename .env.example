# ---- Server ----
PORT=3000

# ---- Adzuna (https://developer.adzuna.com) ----
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=gb

# ---- Reed (https://www.reed.co.uk/developers) ----
REED_API_KEY=your_reed_api_key

# ---- Jooble (https://jooble.org/api/about) ----
JOOBLE_API_KEY=your_jooble_api_key

# ---- Email (Resend HTTP API — https://resend.com) ----
# Uses a plain HTTPS API call rather than SMTP, so it isn't affected by
# free-tier hosting platforms that block outbound SMTP ports.
RESEND_API_KEY=your_resend_api_key
# The default sender below can only email YOUR OWN Resend account address
# until you verify a real domain at resend.com/domains. To email real
# recipients, verify a domain then change this to an address on it.
RESEND_FROM="Job Broadcaster <onboarding@resend.dev>"
